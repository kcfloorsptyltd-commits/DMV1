import { SlashCommandBuilder } from 'discord.js';
import { createEmbed, errorEmbed, successEmbed } from '../../utils/embeds.js';
import { getEconomyData } from '../../utils/economy.js';
import { addBalance } from '../../utils/economy.addBalance.js'; // import the helper above
import { withErrorHandling, createError, ErrorTypes } from '../../utils/errorHandler.js';
import { InteractionHelper } from '../../utils/interactionHelper.js';

export default {
  data: new SlashCommandBuilder()
    .setName('addbalance')
    .setDescription('Add money to a user (admin only)')
    .addUserOption(opt => opt.setName('user').setDescription('User to give money to').setRequired(true))
    .addNumberOption(opt => opt.setName('amount').setDescription('Amount to add').setRequired(true))
    .addBooleanOption(opt => opt.setName('bank').setDescription('Add to bank instead of wallet').setRequired(false)),

  execute: withErrorHandling(async (interaction, config, client) => {
    // permission check: require manage guild or administrator (adjust to your policy)
    if (!interaction.memberPermissions?.has?.('ManageGuild') && !interaction.memberPermissions?.has?.('Administrator')) {
      throw createError('Unauthorized', ErrorTypes.AUTH, 'You do not have permission to use this command.');
    }

    const deferred = await InteractionHelper.safeDefer(interaction);
    if (!deferred) return;

    const target = interaction.options.getUser('user', true);
    const amount = interaction.options.getNumber('amount', true);
    const toBank = interaction.options.getBoolean('bank') || false;
    const guildId = interaction.guildId;

    if (target.bot) {
      await InteractionHelper.safeEditReply(interaction, { embeds: [errorEmbed('Bots do not have balances.')] });
      return;
    }

    if (amount <= 0) {
      await InteractionHelper.safeEditReply(interaction, { embeds: [errorEmbed('Please provide an amount greater than zero.')] });
      return;
    }

    // optionally fetch current data for logging or to show old/new
    const before = await getEconomyData(client, guildId, target.id) || { wallet: 0, bank: 0 };
    const updated = await addBalance(client, guildId, target.id, amount, { toBank });

    const fieldName = toBank ? 'Bank' : 'Wallet';
    const embed = createEmbed({
      title: 'Balance Updated',
      description: `Added $${amount.toLocaleString()} to ${target.username}'s ${fieldName}`,
    })
      .addFields(
        { name: 'Before', value: `$${(toBank ? before.bank : before.wallet).toLocaleString()}`, inline: true },
        { name: 'After', value: `$${(toBank ? updated.bank : updated.wallet).toLocaleString()}`, inline: true }
      );

    await InteractionHelper.safeEditReply(interaction, { embeds: [embed] });
  }, { command: 'addbalance' })
};
